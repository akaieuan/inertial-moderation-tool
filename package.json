{
  "name": "inertial",
  "version": "0.0.1",
  "private": true,
  "description": "Multimodal AI content moderation toolkit + reference app. Federation-native, human-in-the-loop, structured signals not verdicts.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.4.1",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "smoke": "node scripts/smoke.mjs",
    "seed": "node scripts/seed.mjs",
    "eval": "node scripts/eval.mjs",
    "demo:setup": "test -d apps/inertial-app/node_modules/electron/dist || node apps/inertial-app/node_modules/electron/install.js",
    "predemo": "pnpm demo:setup",
    "demo": "concurrently -n runciter,gateway,app -c cyan,green,magenta --kill-others-on-fail 'pnpm --filter @inertial/runciter dev' 'pnpm --filter @inertial/gateway dev' 'pnpm --filter @inertial/app dev'",
    "db:up": "docker compose up -d postgres && docker compose exec -T postgres bash -c 'until pg_isready -U aur -d aur; do sleep 1; done'",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:migrate": "pnpm --filter @inertial/db db:migrate",
    "db:generate": "pnpm --filter @inertial/db db:generate",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "concurrently": "^9.1.2",
    "puppeteer": "^24.42.0",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3",
    "@inertial/agents-cloud": "workspace:*",
    "@inertial/agents-context": "workspace:*",
    "@inertial/agents-text": "workspace:*",
    "@inertial/agents-video": "workspace:*",
    "@inertial/agents-vision": "workspace:*",
    "@inertial/core": "workspace:*",
    "@inertial/db": "workspace:*",
    "@inertial/eval": "workspace:*"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "onnxruntime-node",
      "protobufjs",
      "sharp"
    ]
  }
}
