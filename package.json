{
  "name": "aur",
  "version": "0.0.1",
  "private": true,
  "description": "Multimodal AI content moderation toolkit + reference app. Federation-native, human-in-the-loop, structured signals not verdicts.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.4.1",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "smoke": "node scripts/smoke.mjs",
    "seed": "node scripts/seed.mjs",
    "db:up": "docker compose up -d postgres && docker compose exec -T postgres bash -c 'until pg_isready -U aur -d aur; do sleep 1; done'",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:migrate": "pnpm --filter @aur/db db:migrate",
    "db:generate": "pnpm --filter @aur/db db:generate",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.3",
    "@types/node": "^22.10.5"
  }
}
