{
  "name": "@inertial/gateway",
  "version": "0.0.1",
  "private": true,
  "description": "Hono ingest service. Normalizes inbound platform payloads into ContentEvents and forwards to the worker.",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@inertial/schemas": "workspace:*",
    "hono": "^4.6.14",
    "@hono/node-server": "^1.13.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "@types/node": "^22.10.5"
  }
}
