{
  "name": "@aur/db",
  "version": "0.0.1",
  "private": true,
  "description": "Drizzle + Postgres + pgvector persistence. Stores ContentEvents, signals, traces, reviews, policies, hash-chained audit log, and embeddings for similarity search.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "default": "./dist/schema.js"
    },
    "./dev": {
      "types": "./dist/dev.d.ts",
      "default": "./dist/dev.js"
    }
  },
  "files": ["dist", "migrations", "drizzle.config.ts"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist .turbo *.tsbuildinfo",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx bin/migrate.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aur/schemas": "workspace:*",
    "@electric-sql/pglite": "^0.2.17",
    "drizzle-orm": "^0.40.0",
    "postgres": "^3.4.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8",
    "@types/node": "^22.10.5"
  }
}
