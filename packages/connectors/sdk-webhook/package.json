{
  "name": "@inertial/connectors-sdk-webhook",
  "version": "0.0.1",
  "private": true,
  "description": "SDK webhook connector. Receives ContentEvents from external integrations via the public SDK.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@inertial/schemas": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
}
